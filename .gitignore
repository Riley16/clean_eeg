# --- Project-specific ignores ---
# Add here if you generate data, figures, logs, or large artifacts.
# Use `**/data/*` (not `**/data/`) so specific files inside data/ can
# be re-included below via `!` exception patterns.
**/data/*
**/test_data/
# Exception: the audit's annotation-vocab whitelist is operator-curated
# but should grow across audits and be shared across contributors.
!data/annotation_vocab_whitelist.json
logs/
*.log

# Local-only exploration / reference material (Claude scratch space, not part of the package)
context/
misc_scripts/
# Notebooks: executed outputs can balloon to 100s of MB (embedded
# matplotlib PNGs). Force-add with `git add -f` if you intentionally
# want a notebook tracked.
notebooks/
